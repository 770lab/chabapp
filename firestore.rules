rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Utilisateurs
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Posts
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null
                    && resource.data.authorUid == request.auth.uid;

      // Commentaires
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
      }
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if request.auth != null
                  && (resource.data.toUid == request.auth.uid
                      || resource.data.fromUid == request.auth.uid);
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && resource.data.toUid == request.auth.uid;
    }

    // Config (admins) — seuls les admins existants peuvent modifier
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid in get(/databases/$(database)/documents/config/admins).data.uids;
    }

    // Vidéos YouTube — lecture publique, ajout/suppression admins uniquement
    match /yt_videos/{videoId} {
      allow read: if true;
      allow create, delete: if request.auth != null
                            && request.auth.uid in get(/databases/$(database)/documents/config/admins).data.uids;
    }

    // Chaînes YouTube — lecture publique, ajout/suppression admins uniquement
    match /yt_channels/{channelId} {
      allow read: if true;
      allow create, delete: if request.auth != null
                            && request.auth.uid in get(/databases/$(database)/documents/config/admins).data.uids;
    }
  }
}
